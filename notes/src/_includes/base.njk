<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{{ title }} | Jon Bjork Music</title>
<meta name="description" content="{{ description or 'Notes on guitar practice, technique, and long-term musical development.' }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description or 'Notes on guitar practice, technique, and long-term musical development.' }}">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta name="theme-color" content="#0d0d0d">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-ZZW8ZW4P5D"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-ZZW8ZW4P5D');
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Lato:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
<style>
  .notes-wrap { max-width: 720px; margin: 0 auto; padding: 80px 24px 96px; }
  .notes-header { margin-bottom: 64px; padding-bottom: 40px; border-bottom: 1px solid var(--border); }
  .notes-header h1 { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: clamp(2.8rem, 7vw, 4.5rem); letter-spacing: 0.02em; text-transform: uppercase; line-height: 1.0; color: var(--white); margin-bottom: 20px; }
  .notes-header p { font-size: 1.2rem; color: var(--muted); line-height: 1.6; max-width: 580px; }
  .notes-list { list-style: none; }
  .notes-list-item { padding: 32px 0; border-bottom: 1px solid var(--border); }
  .notes-list-item:last-child { border-bottom: none; }
  .notes-list-item a { text-decoration: none; display: block; transition: opacity 0.2s; }
  .notes-list-item a:hover { opacity: 0.85; }
  .notes-list-item h2 { font-family: 'Oswald', sans-serif; font-weight: 600; font-size: clamp(1.5rem, 3.5vw, 2rem); letter-spacing: 0.01em; text-transform: uppercase; line-height: 1.15; color: var(--white); margin-bottom: 12px; }
  .notes-list-item p { font-size: 1.1rem; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .notes-list-item .meta { font-family: 'Oswald', sans-serif; font-size: 0.85rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); }
  .essay-header { margin-bottom: 56px; padding-bottom: 40px; border-bottom: 1px solid var(--border); }
  .essay-eyebrow { font-family: 'Oswald', sans-serif; font-weight: 400; font-size: 1.05rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--purple-lt); display: block; margin-bottom: 24px; }
  .essay-eyebrow a { color: inherit; text-decoration: none; transition: color 0.2s; }
  .essay-eyebrow a:hover { color: var(--white); }
  .essay-title { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: clamp(2.4rem, 6vw, 4rem); letter-spacing: 0.01em; text-transform: uppercase; line-height: 1.05; color: var(--white); margin-bottom: 24px; }
  .essay-meta { font-family: 'Oswald', sans-serif; font-size: 0.95rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); }
  .essay-body { font-family: 'Lato', sans-serif; font-weight: 300; font-size: 1.25rem; line-height: 1.75; color: var(--off); }
  .essay-body p { margin-bottom: 1.5em; }
  .essay-body h2 { font-family: 'Oswald', sans-serif; font-weight: 600; font-size: clamp(1.6rem, 3.5vw, 2.2rem); letter-spacing: 0.02em; text-transform: uppercase; line-height: 1.15; color: var(--white); margin-top: 2.6em; margin-bottom: 0.9em; }
  .essay-body em { font-style: italic; }
  .essay-body strong { color: var(--white); font-weight: 700; }
  .essay-body a { color: var(--purple-lt); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; transition: color 0.2s; }
  .essay-body a:hover { color: var(--white); }
  .essay-body img { max-width: 100%; height: auto; border-radius: 8px; margin: 2em 0; }
  .essay-body blockquote { border-left: 2px solid var(--purple); padding: 4px 0 4px 24px; margin: 2em 0; color: var(--white); font-style: italic; }
  .essay-body iframe { max-width: 100%; border-radius: 8px; margin: 2em 0; aspect-ratio: 16 / 9; width: 100%; height: auto; border: 0; }
  .essay-body audio { width: 100%; margin: 1.5em 0; }
  .essay-cta { margin-top: 80px; padding: 40px 32px; background: var(--card); border: 1px solid var(--border); border-radius: 12px; text-align: center; position: relative; overflow: hidden; }
  .essay-cta::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--purple), var(--purple-lt)); }
  .essay-cta h3 { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 1.6rem; letter-spacing: 0.02em; text-transform: uppercase; color: var(--white); margin-bottom: 14px; }
  .essay-cta p { color: var(--muted); font-size: 1.1rem; margin-bottom: 24px; }
  .essay-cta a { display: inline-block; font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 1.05rem; letter-spacing: 0.14em; text-transform: uppercase; background: var(--purple); color: var(--white); padding: 16px 36px; border-radius: 10px; text-decoration: none; transition: background 0.2s; }
  .essay-cta a:hover { background: var(--purple-lt); }
  @media (max-width: 600px) {
    .notes-wrap { padding: 48px 20px 72px; }
    .essay-body { font-size: 1.15rem; }
  }
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="https://www.jonbjorkmusic.com/" aria-label="Jon Bjork Music — Guitarist, Coach, Composer">
    <span class="nav-logo-row">
      <span class="nav-logo-name">Jon Bjork</span>
      <span class="nav-logo-divider" aria-hidden="true"></span>
      <span class="nav-logo-tag">Music</span>
    </span>
    <span class="nav-tagline">Guitarist &middot; Coach &middot; Composer</span>
  </a>
  <div class="nav-right">
    <a class="nav-link" href="https://www.jonbjorkmusic.com/start">Coaching</a>
    <a class="nav-link" href="https://www.jonbjorkmusic.com/courses">Courses</a>
    <a class="nav-link" href="https://www.jonbjorkmusic.com/notes/">Notes</a>
    <a class="nav-link" href="https://www.jonbjorkmusic.com/#about">About</a>
    <a class="nav-btn" href="https://www.jonbjorkmusic.com/coaching">1-on-1 Coaching</a>
  </div>
  <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
    <span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu" role="menu">
  <a class="nav-link" href="https://www.jonbjorkmusic.com/start">Coaching</a>
  <a class="nav-link" href="https://www.jonbjorkmusic.com/courses">Courses</a>
  <a class="nav-link" href="https://www.jonbjorkmusic.com/notes/">Notes</a>
  <a class="nav-link" href="https://www.jonbjorkmusic.com/#about">About</a>
  <a class="nav-btn" href="https://www.jonbjorkmusic.com/coaching">1-on-1 Coaching</a>
</div>

<div class="notes-wrap">
  {{ content | safe }}
</div>

<footer>
  <a class="footer-logo" href="https://www.jonbjorkmusic.com/" aria-label="Jon Bjork Music — Guitarist, Coach, Composer">
    <span class="footer-logo-row">
      <span class="footer-logo-name">Jon Bjork</span>
      <span class="footer-logo-divider" aria-hidden="true"></span>
      <span class="footer-logo-tag">Music</span>
    </span>
    <span class="footer-tagline">Guitarist &middot; Coach &middot; Composer</span>
  </a>
  <div class="footer-links">
    <a class="footer-link" href="https://www.jonbjorkmusic.com/">Home</a>
    <a class="footer-link" href="https://www.jonbjorkmusic.com/coaching">1-on-1</a>
    <a class="footer-link" href="https://www.jonbjorkmusic.com/courses">Courses</a>
    <a class="footer-link" href="https://youtube.com/@jonbjork" target="_blank">YouTube</a>
  </div>
  <a class="footer-link" href="https://www.jonbjorkmusic.com/legal">Legal</a>
  <div class="footer-copy">&copy; 2026 Jon Bjork Music</div>
</footer>

<script>
  // --- Nav spacing: measure nav and apply to body padding ---
  (function() {
    function syncNavSpacing() {
      var nav = document.querySelector('nav');
      if (!nav) return;
      var h = nav.offsetHeight;
      document.body.style.paddingTop = h + 'px';
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncNavSpacing);
    } else {
      syncNavSpacing();
    }
    window.addEventListener('load', syncNavSpacing);
    window.addEventListener('resize', syncNavSpacing);
  })();

  // --- Mobile menu toggle ---
  (function() {
    var toggle = document.getElementById('navToggle');
    var menu = document.getElementById('mobileMenu');
    if (!toggle || !menu) return;

    function closeMenu() {
      toggle.classList.remove('is-open');
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
    }
    function openMenu() {
      toggle.classList.add('is-open');
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
    }
    toggle.addEventListener('click', function() {
      if (menu.classList.contains('is-open')) { closeMenu(); } else { openMenu(); }
    });
    menu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', closeMenu);
    });
    window.addEventListener('resize', function() {
      if (window.innerWidth > 900 && menu.classList.contains('is-open')) closeMenu();
    });
  })();
</script>

</body>
</html>
